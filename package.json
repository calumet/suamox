{
  "name": "suamox",
  "version": "0.1.0",
  "description": "Meta-framework with SSR/SSG, filesystem routing, and islands architecture",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter \"@calumet/suamox*\" build",
    "dev": "pnpm --parallel --filter \"@calumet/suamox*\" dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "framework",
    "ssr",
    "ssg",
    "react",
    "vite",
    "hono"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "@calumet/elise-linter": "^0.1.2",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.39.2",
    "prettier": "^3.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.19.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
